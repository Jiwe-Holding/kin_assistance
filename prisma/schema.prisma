generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Demande {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String
  service     String
  departure   String?
  destination String?
  description String
  urgency     String   @default("normal")
  status      String   @default("nouveau") // "nouveau", "en_cours", "termine"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
